generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String
  phone             String?
  role              String   @default("BUYER")
  status            String   @default("ACTIVE")
  storeId           String?
  allowedStores     String?
  allowedClusters   String?
  allowedCategories String?
  lastAccess        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  CampaignBuyer     CampaignBuyer[]

  @@map("users")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  clusterId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

model Cluster {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clusters")
}

model Campaign {
  id               String        @id @default(cuid())
  name             String
  code             String        @unique
  description      String?
  type             String
  status           String        @default("DRAFT")
  startDate        DateTime
  endDate          DateTime
  deadlines        String?
  totalSlots       Int           @default(0)
  filledSlots      Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  buyers           CampaignBuyer[]
  pages            Page[]
  promotionalItems PromotionalItem[]

  @@map("campaigns")
}

model CampaignBuyer {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  itemCount  Int      @default(0)
  createdAt  DateTime @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([campaignId, userId])
  @@map("campaign_buyers")
}

model Page {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  order      Int
  type       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  modules    Module[]

  @@map("pages")
}

model Module {
  id         String   @id @default(cuid())
  pageId     String
  name       String
  order      Int
  slotCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  page       Page     @relation(fields: [pageId], references: [id])
  slots      Slot[]

  @@map("modules")
}

model Slot {
  id         String   @id @default(cuid())
  moduleId   String
  label      String
  buyerId    String?
  categoryId String?
  priority   Int?
  status     String   @default("EMPTY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  module           Module           @relation(fields: [moduleId], references: [id])
  promotionalItem  PromotionalItem?

  @@map("slots")
}

model PromotionalItem {
  id                      String   @id @default(cuid())
  campaignId              String
  slotId                  String   @unique
  productSeqproduto       String
  descriptionErp          String
  descriptionNewspaper    String
  offerType               String   @default("SIMPLE_PRICE")
  exposureType            String   @default("SINGLE")
  sellOutValue            Float?
  sellOutAgreementNumber  String?
  insertValue             Float?
  insertBoxAgreementNumber String?
  promotionalPrice        Float
  pmzNew                  Float
  offerMarginPercent      Float
  status                  String   @default("PENDING")
  notes                   String?
  imageUrl                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  slot     Slot     @relation(fields: [slotId], references: [id])

  @@map("promotional_items")
}

model Product {
  id               String   @id @default(cuid())
  seqproduto       String   @unique
  codProd          String
  description      String
  descriptionErp   String
  familyCode       String
  familyName       String
  department       String
  supplier         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  commercialData   ProductCommercialData[]
}

model ProductCommercialData {
  id                       String   @id @default(cuid())
  productId                String
  filial                   String
  pmz                      Float
  salePrice                Float
  abcCurve                 String
  storeRole                String
  salesTrend               String
  priceSensitivity         String
  lifecycle                String
  stockQty                 Int
  avgSales30d              Int
  lowestCompetitorPrice90d Float?
  competitorResearchDate   DateTime?
  competitorName           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, filial])
  @@map("product_commercial_data")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  oldValue  String?
  newValue  String?
  reason    String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
