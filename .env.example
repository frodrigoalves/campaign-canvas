VITE_API_URL=http://localhost:3333
VITE_WS_URL=ws://localhost:3333
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Backend (quando criar cevaroli-api)
DATABASE_URL=postgresql://cevaroli:senha@localhost:5432/cevaroli_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=troque-por-256-bits
JWT_EXPIRES_IN=8h

STORAGE_DRIVER=minio
S3_BUCKET=cevaroli-assets
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

MARGIN_WARN_THRESHOLD=5
MARGIN_CRITICAL_THRESHOLD=0
